{
  "name": "ai-toolkit-cli",
  "version": "1.0.0",
  "description": "AI-powered development toolkit for code analysis, documentation, and automation",
  "main": "dist/index.js",
  "bin": {
    "ai-toolkit": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "toolkit",
    "cli",
    "code-analysis",
    "documentation",
    "testing",
    "security",
    "automation"
  ],
  "author": "Longing Bot <longing@openclaw.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Longing-bot/ai-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/Longing-bot/ai-toolkit/issues"
  },
  "homepage": "https://github.com/Longing-bot/ai-toolkit#readme",
  "dependencies": {
    "commander": "^10.0.0",
    "chalk": "^5.0.0",
    "ora": "^6.0.0",
    "inquirer": "^9.0.0",
    "glob": "^10.0.0",
    "fs-extra": "^11.0.0",
    "yaml": "^2.0.0",
    "json5": "^2.0.0",
    "semver": "^7.0.0",
    "node-fetch": "^3.0.0",
    "axios": "^1.0.0",
    "joi": "^17.0.0",
    "lodash": "^4.0.0",
    "chokidar": "^3.0.0",
    "handlebars": "^4.0.0",
    "marked": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/lodash": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "@types/inquirer": "^9.0.0",
    "@types/fs-extra": "^11.0.0",
    "@types/glob": "^8.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "type": "commonjs"
}
